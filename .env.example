# Скопируй в .env и заполни. .env в git не попадёт (см. .gitignore).

# HTTP-порт сервиса
PORT=8080

# OpenRouter
OPENROUTER_API_KEY=
# Модель LLM. Примеры:
#   google/gemini-2.0-flash-001
#   google/gemma-2-27b-it
#   anthropic/claude-haiku-4.5
LLM_MODEL=google/gemini-2.0-flash-001

# Системный промпт ассистента
SYSTEM_PROMPT=Ты дружелюбный голосовой ассистент. Отвечай кратко, на русском языке, простыми фразами, без markdown.

# Yandex SpeechKit
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# Голоса: alena, filipp, jane, omazh, zahar, ermil, madirus, marina, lera, dasha
# Подробнее: https://yandex.cloud/ru/docs/speechkit/tts/voices
YANDEX_VOICE=alena
# Эмоция (поддерживается не у всех голосов): good, neutral, evil
YANDEX_EMOTION=good
# Скорость 0.1..3.0 (1.0 — норма; для разговорного стиля попробуй 1.1)
YANDEX_SPEED=1.0
