# Caddy слушает HTTPS на нестандартном порту 8443 (на 80/443 на сервере другой сайт).
# Использует САМОПОДПИСАННЫЙ сертификат — браузер один раз попросит «Принять риск»,
# после этого микрофон работает (https-контекст для getUserMedia).
#
# Для нормального публичного HTTPS с Let's Encrypt нужно либо освободить порт 80/443,
# либо настраивать DNS-01 challenge — это отдельная задача.

{
    local_certs
}

voice.gendoctor.ru:8443, :8443 {
    encode gzip
    reverse_proxy voice-assistant:8080
}
