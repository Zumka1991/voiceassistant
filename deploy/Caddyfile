# Caddy слушает HTTPS на 8443 с самоподписанным сертификатом (внутренний CA Caddy).
# Перечислены имена/адреса, по которым клиент может ходить — иначе Caddy
# не знает, на какое имя выпустить cert и SNI не матчится.

gendoctor.ru:8443, 176.119.157.101:8443, localhost:8443 {
    tls internal
    encode gzip
    reverse_proxy voice-assistant:8080
}
